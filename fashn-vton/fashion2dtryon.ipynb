      "source": [
        "# @title 9. \ud83d\ude80 API-Enabled Try-On with Auto Image Display (Run this cell)\n",
        "\n",
        "# Install required packages\n",
        "!pip install flask flask-cors pyngrok pillow matplotlib ipywidgets\n",
        "\n",
        "import flask\n",
        "from flask import Flask, request, jsonify, send_file\n",
        "from flask_cors import CORS\n",
        "import threading\n",
        "import base64\n",
        "from PIL import Image\n",
        "import io\n",
        "import torch\n",
        "import gc\n",
        "import time\n",
        "import json\n",
        "import os\n",
        "import matplotlib.pyplot as plt\n",
        "from IPython.display import display, Image as IPImage, clear_output\n",
        "import ipywidgets as widgets\n",
        "from datetime import datetime\n",
        "\n",
        "# ===== AUTO IMAGE DISPLAY FUNCTION =====\n",
        "def auto_display_result(result_image, person_image=None, garment_image=None, processing_time=None):\n",
        "    \"\"\"Automatically display the result image in Colab\"\"\"\n",
        "\n",
        "    # Clear previous output in this specific area\n",
        "    clear_output(wait=True)\n",
        "\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"\ud83c\udfaf NEW TRY-ON RESULT GENERATED\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    if processing_time:\n",
        "        print(f\"\u23f1\ufe0f Processing time: {processing_time:.2f} seconds\")\n",
        "\n",
        "    # Create figure with appropriate subplots\n",
        "    if person_image and garment_image:\n",
        "        # Show all three images\n",
        "        fig, axes = plt.subplots(1, 3, figsize=(18, 6))\n",
        "\n",
        "        # Person image\n",
        "        axes[0].imshow(person_image)\n",
        "        axes[0].set_title(f'\ud83d\udc64 Person Image\\n{person_image.size}', fontsize=12, fontweight='bold')\n",
        "        axes[0].axis('off')\n",
        "\n",
        "        # Garment image\n",
        "        axes[1].imshow(garment_image)\n",
        "        axes[1].set_title(f'\ud83d\udc55 Garment Image\\n{garment_image.size}', fontsize=12, fontweight='bold')\n",
        "        axes[1].axis('off')\n",
        "\n",
        "        # Result image\n",
        "        axes[2].imshow(result_image)\n",
        "        axes[2].set_title(f'\u2728 Try-On Result\\n{result_image.size}', fontsize=12, fontweight='bold', color='green')\n",
        "        axes[2].axis('off')\n",
        "\n",
        "        plt.suptitle('\u2705 Virtual Try-On Successful!', fontsize=14, fontweight='bold', color='blue')\n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "\n",
        "    else:\n",
        "        # Show just the result\n",
        "        plt.figure(figsize=(10, 10))\n",
        "        plt.imshow(result_image)\n",
        "        plt.title('\ud83c\udfaf Try-On Result', fontsize=14, fontweight='bold')\n",
        "        plt.axis('off')\n",
        "        plt.show()\n",
        "\n",
        "    # Save with timestamp\n",
        "    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')\n",
        "    filename = f\"tryon_result_{timestamp}.png\"\n",
        "    result_image.save(filename)\n",
        "    print(f\"\ud83d\udcbe Saved: {filename}\")\n",
        "\n",
        "    # Show download link/button\n",
        "    from google.colab import files\n",
        "    print(f\"\\n\ud83d\udce5 To download, click: files.download('{filename}')\")\n",
        "\n",
        "    # Display file info\n",
        "    file_size = os.path.getsize(filename) / 1024  # KB\n",
        "    print(f\"\ud83d\udcca File size: {file_size:.1f} KB\")\n",
        "    print(\"=\"*60 + \"\\n\")\n",
        "\n",
        "    return filename\n",
        "\n",
        "# ===== YOUR EXISTING FUNCTIONS FROM CELL 9 =====\n",
        "def resize_for_memory(image, max_size=(512, 768)):\n",
        "    \"\"\"Resize image to fit in memory (same as your original function)\"\"\"\n",
        "    image.thumbnail(max_size, Image.Resampling.LANCZOS)\n",
        "    return image\n",
        "\n",
        "def base64_to_image(base64_string):\n",
        "    \"\"\"Convert base64 string to PIL Image\"\"\"\n",
        "    # Remove data URL prefix if present (e.g., \"data:image/jpeg;base64,\")\n",
        "    if ',' in base64_string:\n",
        "        base64_string = base64_string.split(',')[1]\n",
        "\n",
        "    image_bytes = base64.b64decode(base64_string)\n",
        "    image = Image.open(io.BytesIO(image_bytes)).convert(\"RGB\")\n",
        "    return image\n",
        "\n",
        "def image_to_base64(image):\n",
        "    \"\"\"Convert PIL Image to base64 string for returning\"\"\"\n",
        "    buffered = io.BytesIO()\n",
        "    image.save(buffered, format=\"PNG\")\n",
        "    return base64.b64encode(buffered.getvalue()).decode()\n",
        "\n",
        "# ===== CHECK IF PIPELINE IS LOADED =====\n",
        "if 'pipeline' not in globals():\n",
        "    raise RuntimeError(\"\u274c Pipeline not loaded! Please run the pipeline initialization cell first.\")\n",
        "else:\n",
        "    print(\"\u2705 Pipeline loaded and ready\")\n",
        "\n",
        "# ===== CREATE FLASK APP =====\n",
        "import uuid\n",
        "import queue\n",
        "import threading\n",
        "\n",
        "app = Flask(__name__)\n",
        "CORS(app)  # Enable CORS for all routes\n",
        "\n",
        "# ===== JOB QUEUE SETUP =====\n",
        "jobs = {}\n",
        "job_queue = queue.Queue()\n",
        "\n",
        "def worker():\n",
        "    \"\"\"Background worker to process try-on jobs sequentially\"\"\"\n",
        "    while True:\n",
        "        try:\n",
        "            job_id = job_queue.get()\n",
        "            if job_id is None:\n",
        "                break\n",
        "                \n",
        "            job = jobs[job_id]\n",
        "            job['status'] = 'processing'\n",
        "            \n",
        "            print(f\"\\n\" + \"=\"*50)\n",
        "            print(f\"\ud83d\udd04 [{time.strftime('%H:%M:%S')}] Processing job {job_id}\")\n",
        "            \n",
        "            start_time = time.time()\n",
        "            \n",
        "            # Extract images\n",
        "            custom_person = job['person_image']\n",
        "            custom_garment = job['garment_image']\n",
        "            category = job['category']\n",
        "            \n",
        "            # Apply resizing\n",
        "            custom_person = resize_for_memory(custom_person)\n",
        "            custom_garment = resize_for_memory(custom_garment)\n",
        "            \n",
        "            print(f\"\ud83d\udccf Resized images: Person {custom_person.size}, Garment {custom_garment.size}\")\n",
        "            \n",
        "            # Clear cache\n",
        "            torch.cuda.empty_cache()\n",
        "            gc.collect()\n",
        "            \n",
        "            # Run inference\n",
        "            print(f\"\ud83d\udd04 Running try-on with your images...\")\n",
        "            custom_result = pipeline(\n",
        "                person_image=custom_person,\n",
        "                garment_image=custom_garment,\n",
        "                category=category,\n",
"                num_inference_steps=15\n",
        "            )\n",
        "            \n",
        "            # Extract the result image\n",
        "            if hasattr(custom_result, 'images'):\n",
        "                result_image = custom_result.images[0]\n",
        "            elif isinstance(custom_result, dict) and 'images' in custom_result:\n",
        "                result_image = custom_result['images'][0]\n",
        "            elif isinstance(custom_result, list):\n",
        "                result_image = custom_result[0]\n",
        "            else:\n",
        "                result_image = custom_result\n",
        "                \n",
        "            # Calculate processing time\n",
        "            processing_time = time.time() - start_time\n",
        "            \n",
        "            # Save the result\n",
        "            timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')\n",
        "            filename = f\"tryon_result_{job_id[:8]}_{timestamp}.png\"\n",
        "            result_image.save(filename)\n",
        "            print(f\"\ud83d\udcbe Saved result to {filename}\")\n",
        "            \n",
        "            # Automatically display the image in Colab cell output (if auto_display exists)\n",
        "            try:\n",
        "                auto_display_result(result_image, custom_person, custom_garment, processing_time)\n",
        "            except Exception as e:\n",
        "                print(f\"\u26a0\ufe0f Auto display failed (non-fatal): {str(e)}\")\n",
        "            \n",
        "            # Convert result to base64\n",
        "            result_base64 = image_to_base64(result_image)\n",
        "            \n",
        "            # Update job status\n",
        "            job['status'] = 'completed'\n",
        "            job['result_image'] = f\"data:image/png;base64,{result_base64}\"\n",
        "            job['result_filename'] = filename\n",
        "            job['processing_time'] = round(processing_time, 2)\n",
        "            \n",
        "            print(f\"\u2705 Job {job_id} complete in {processing_time:.2f} seconds\")\n",
        "            print(\"=\"*50)\n",
        "            \n",
        "            # Free up memory\n",
        "            del job['person_image']\n",
        "            del job['garment_image']\n",
        "            \n",
        "        except Exception as e:\n",
        "            print(f\"\u274c Error processing job {job_id}: {str(e)}\")\n",
        "            import traceback\n",
        "            traceback.print_exc()\n",
        "            if 'job_id' in locals() and job_id in jobs:\n",
        "                jobs[job_id]['status'] = 'failed'\n",
        "                jobs[job_id]['error'] = str(e)\n",
        "        finally:\n",
        "            if 'job_id' in locals():\n",
        "                job_queue.task_done()\n",
        "\n",
        "# Start worker thread\n",
        "worker_thread = threading.Thread(target=worker, daemon=True)\n",
        "worker_thread.start()\n",
        "print(\"\u2705 Background worker started\")\n",
        "\n",
        "# ===== API ENDPOINT THAT QUEUES YOUR TRY-ON JOB =====\n",
        "@app.route('/tryon', methods=['POST'])\n",
        "def tryon():\n",
        "    \"\"\"\n",
        "    This endpoint parses the request, queues the job, and returns a job_id.\n",
        "    \"\"\"\n",
        "    try:\n",
        "        data = request.json\n",
        "\n",
        "        if not data:\n",
        "            return jsonify({'error': 'No data provided'}), 400\n",
        "\n",
        "        if 'person_image' not in data or 'garment_image' not in data:\n",
        "            return jsonify({'error': 'Both person_image and garment_image required'}), 400\n",
        "\n",
        "        print(f\"\\n\ud83d\udce5 [{time.strftime('%H:%M:%S')}] Received API request - Queueing Job\")\n",
        "\n",
        "        # Convert base64 to images immediately so we validate them early\n",
        "        custom_person = base64_to_image(data['person_image'])\n",
        "        custom_garment = base64_to_image(data['garment_image'])\n",
        "        category = data.get('category', 'tops')\n",
        "\n",
        "        job_id = str(uuid.uuid4())\n",
        "        \n",
        "        jobs[job_id] = {\n",
        "            'id': job_id,\n",
        "            'status': 'pending',\n",
        "            'person_image': custom_person,\n",
        "            'garment_image': custom_garment,\n",
        "            'category': category,\n",
        "            'created_at': time.time()\n",
        "        }\n",
        "        \n",
        "        job_queue.put(job_id)\n",
        "        \n",
        "        return jsonify({\n",
        "            'success': True,\n",
        "            'message': 'Job queued successfully',\n",
        "            'job_id': job_id,\n",
        "            'status': 'pending'\n",
        "        })\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f\"\u274c Error queueing job: {str(e)}\")\n",
        "        import traceback\n",
        "        traceback.print_exc()\n",
        "        return jsonify({\n",
        "            'success': False,\n",
        "            'error': str(e)\n",
        "        }), 500\n",
        "\n",
        "# ===== NEW ENDPOINT TO CHECK STATUS =====\n",
        "@app.route('/status/<job_id>', methods=['GET'])\n",
        "def get_status(job_id):\n",
        "    \"\"\"Check the status of a queued try-on job\"\"\"\n",
        "    if job_id not in jobs:\n",
        "        return jsonify({'success': False, 'error': 'Job not found'}), 404\n",
        "        \n",
        "    job = jobs[job_id]\n",
        "    status = job['status']\n",
        "    \n",
        "    response = {\n",
        "        'success': True,\n",
        "        'job_id': job_id,\n",
        "        'status': status\n",
        "    }\n",
        "    \n",
        "    if status == 'completed':\n",
        "        response['result_image'] = job['result_image']\n",
        "        response['result_filename'] = job['result_filename']\n",
        "        response['processing_time'] = job['processing_time']\n",
        "    elif status == 'failed':\n",
        "        response['error'] = job.get('error', 'Unknown error')\n",
        "        \n",
        "    return jsonify(response)\n",
        "\n",
        "# ===== NEW ENDPOINT FOR MANUAL DISPLAY =====\n",
        "@app.route('/display/<filename>', methods=['GET'])\n",
        "def display_file(filename):\n",
        "    \"\"\"Display a specific result file in Colab\"\"\"\n",
        "    try:\n",
        "        if os.path.exists(filename):\n",
        "            image = Image.open(filename)\n",
        "            auto_display_result(image)\n",
        "            return jsonify({'success': True, 'message': f'Displayed {filename}'})\n",
        "        else:\n",
        "            return jsonify({'error': 'File not found'}), 404\n",
        "    except Exception as e:\n",
        "        return jsonify({'error': str(e)}), 500\n",
        "\n",
        "# ===== HEALTH CHECK ENDPOINT =====\n",
        "@app.route('/health', methods=['GET'])\n",
        "def health():\n",
        "    \"\"\"Check if API is ready\"\"\"\n",
        "    return jsonify({\n",
        "        'status': 'healthy',\n",
        "        'pipeline_loaded': 'pipeline' in globals(),\n",
        "        'gpu': torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'None',\n",
        "        'message': 'API is running and waiting for requests',\n",
        "        'endpoints': {\n",
        "            'POST /tryon': 'Send images for virtual try-on (returns job_id)',\n",
        "            'GET /status/<job_id>': 'Check status and get result of a try-on job',\n",
        "            'GET /health': 'Check API status',\n",
        "            'GET /display/<filename>': 'Display a specific result file'\n",
        "        }\n",
        "    })\n",
        "\n",
        "# ===== STATS ENDPOINT =====\n",
        "@app.route('/stats', methods=['GET'])\n",
        "def stats():\n",
        "    \"\"\"Get API statistics\"\"\"\n",
        "    return jsonify({\n",
        "        'total_requests': len(request_history),\n",
        "        'average_time': sum(request_history) / len(request_history) if request_history else 0,\n",
        "        'last_request': request_history[-1] if request_history else None\n",
        "    })\n",
        "\n",
        "# ===== START THE SERVER =====\n",
        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"\ud83d\ude80 STARTING API SERVER WITH AUTO DISPLAY\")\n",
        "print(\"=\"*60)\n",
        "\n",
        "# Track requests\n",
        "request_history = []\n",
        "\n",
        "def run_flask():\n",
        "    \"\"\"Run Flask app\"\"\"\n",
        "    app.run(host='0.0.0.0', port=5000, debug=False, use_reloader=False)\n",
        "\n",
        "# Start Flask in a background thread\n",
        "flask_thread = threading.Thread(target=run_flask)\n",
        "flask_thread.daemon = True\n",
        "flask_thread.start()\n",
        "\n",
        "print(\"\u2705 Flask server started on port 5000\")\n",
        "\n",
        "# Install and setup ngrok\n",
        "!pip install pyngrok > /dev/null 2>&1\n",
        "from pyngrok import ngrok\n",
        "\n",
        "# Kill any existing ngrok tunnels\n",
        "ngrok.kill()\n",
        "\n",
        "# Your ngrok authtoken (REPLACE WITH YOUR ACTUAL TOKEN)\n",
        "NGROK_AUTH_TOKEN = \"3ARUdWlz7OlVeY4wsADdXTwoPMb_3izioX8tHVZQhC9sQWrxF\"  # <-- REPLACE THIS\n",
        "\n",
        "# Authenticate ngrok\n",
        "!ngrok authtoken {NGROK_AUTH_TOKEN}\n",
        "\n",
        "# Create tunnel\n",
        "public_url = ngrok.connect(5000)\n",
        "url_string = str(public_url).split('\"')[1] if '\"' in str(public_url) else str(public_url)\n",
        "\n",
        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"\u2705 API IS READY!\")\n",
        "print(\"=\"*60)\n",
        "print(f\"\\n\ud83d\udd17 Public URL: {url_string}\")\n",
        "print(\"\\n\ud83d\udcdd ENDPOINTS:\")\n",
        "print(f\"   POST {url_string}/tryon  - Send images for virtual try-on\")\n",
        "print(f\"   GET  {url_string}/health - Check API status\")\n",
        "print(f\"   GET  {url_string}/stats  - View API statistics\")\n",
        "print(f\"   GET  {url_string}/display/<filename> - Display a result file\")\n",
        "\n",
        "print(\"\\n\ud83d\udce6 Expected JSON format:\")\n",
        "print('''\n",
        "{\n",
        "    \"person_image\": \"data:image/jpeg;base64,/9j/4AAQSkZJRg...\",\n",
        "    \"garment_image\": \"data:image/jpeg;base64,/9j/4AAQSkZJRg...\",\n",
        "    \"category\": \"tops\"  // optional, defaults to \"tops\"\n",
        "}\n",
        "''')\n",
        "\n",
        "# Test the endpoint\n",
        "print(\"\\n\ud83d\udd0d Testing connection...\")\n",
        "import requests\n",
        "try:\n",
        "    test_response = requests.get(f\"{url_string}/health\", timeout=5)\n",
        "    if test_response.status_code == 200:\n",
        "        print(f\"\u2705 API is live! {test_response.json()}\")\n",
        "except:\n",
        "    print(\"\u26a0\ufe0f Health check failed, but server might still be starting...\")\n",
        "\n",
        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"\ud83d\udfe2 SERVER IS RUNNING - Waiting for API calls...\")\n",
        "print(\"   \ud83d\udcf8 Images will appear AUTOMATICALLY when generated!\")\n",
        "print(\"   Press Ctrl+C to stop\")\n",
        "print(\"=\"*60 + \"\\n\")\n",
        "\n",
        "# ===== DEMO FUNCTION TO TEST AUTO DISPLAY =====\n",
        "def test_auto_display():\n",
        "    \"\"\"Test function to demonstrate auto display\"\"\"\n",
        "    print(\"\\n\ud83e\uddea Testing auto display functionality...\")\n",
        "\n",
        "    # Create a sample image\n",
        "    sample_image = Image.new('RGB', (300, 400), color='lightblue')\n",
        "\n",
        "    # Draw some text on it (simulated with shapes)\n",
        "    from PIL import ImageDraw\n",
        "    draw = ImageDraw.Draw(sample_image)\n",
        "    draw.rectangle([50, 50, 250, 150], fill='darkblue')\n",
        "    draw.text((100, 100), \"TEST\", fill='white')\n",
        "\n",
        "    # Auto display it\n",
        "    auto_display_result(sample_image, processing_time=1.23)\n",
        "\n",
        "    print(\"\u2705 Auto display test complete!\")\n",
        "\n",
        "# Uncomment to test\n",
        "# test_auto_display()\n",
        "\n",
        "print(\"\\n\ud83d\udcdd To manually display any saved result, run:\")\n",
        "print(\"    from PIL import Image\")\n",
        "print(\"    auto_display_result(Image.open('your_filename.png'))\")\n",
        "\n",
        "# ===== MAIN LOOP - This runs continuously waiting for API calls =====\n",
        "request_count = 0\n",
        "try:\n",
        "    while True:\n",
        "        time.sleep(1)\n",
        "        # Optional: Print a heartbeat every minute\n",
        "        if int(time.time()) % 60 == 0:\n",
        "            print(f\"\ud83d\udfe2 [{time.strftime('%H:%M:%S')}] Server running, waiting for requests...\")\n",
        "\n",
        "except KeyboardInterrupt:\n",
        "    print(\"\\n\\n\ud83d\uded1 Shutting down server...\")\n",
        "    ngrok.kill()\n",
        "    print(\"\u2705 Cleanup complete\")"
      ]
    }
